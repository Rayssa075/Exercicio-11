#include <iostream>
#include <fstream>

using namespace std;

int main() {
    // Abre o arquivo físico 'matriz.txt' para leitura
    ifstream arquivo("matriz.txt");
    
    // Verifica se o arquivo foi aberto corretamente
    if (!arquivo.is_open()) {
        cerr << "Erro ao abrir o arquivo matriz.txt!" << endl;
        return 1;
    }

    int matriz[3][3];

    // Lê os elementos do arquivo e preenche a matriz 3x3
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            if (!(arquivo >> matriz[i][j])) {
                cerr << "Erro de leitura: Formato da matriz invalido no arquivo." << endl;
                return 1;
            }
        }
    }
    
    // Fecha o arquivo após a leitura
    arquivo.close();

    int somaPrincipal = 0;
    int somaSecundaria = 0;
    int maiorElemento = matriz[0][0];

    // Realiza os cálculos solicitados
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            // Soma da diagonal principal (onde linha é igual a coluna)
            if (i == j) {
                somaPrincipal += matriz[i][j];
            }
            // Soma da diagonal secundária (onde i + j == 2 para matrizes 3x3)
            if (i + j == 2) {
                somaSecundaria += matriz[i][j];
            }
            // Encontra o maior elemento da matriz
            if (matriz[i][j] > maiorElemento) {
                maiorElemento = matriz[i][j];
            }
        }
    }

    // Exibe os resultados formatados na tela
    cout << "Soma da diagonal principal: " << somaPrincipal << endl;
    cout << "Soma da diagonal secundaria: " << somaSecundaria << endl;
    cout << "Maior elemento da matriz: " << maiorElemento << endl;

    return 0;
}
